<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">faq_question_form.question_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Question Information</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <buttons>
            <button name="save" class="Magendoo\Faq\Block\Adminhtml\Question\Edit\SaveButton"/>
            <button name="save_and_send" class="Magendoo\Faq\Block\Adminhtml\Question\Edit\SaveAndSendButton"/>
            <button name="delete" class="Magendoo\Faq\Block\Adminhtml\Question\Edit\DeleteButton"/>
            <button name="back" class="Magendoo\Faq\Block\Adminhtml\Question\Edit\BackButton"/>
        </buttons>
        <namespace>faq_question_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>faq_question_form.question_form_data_source</dep>
        </deps>
    </settings>
    <dataSource name="question_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="faq/question/save"/>
        </settings>
        <dataProvider class="Magendoo\Faq\Ui\DataProvider\Form\QuestionDataProvider" name="question_form_data_source">
            <settings>
                <requestFieldName>question_id</requestFieldName>
                <primaryFieldName>question_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <!-- General Fieldset -->
    <fieldset name="general">
        <settings>
            <label/>
        </settings>
        <field name="question_id" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">question</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <visible>false</visible>
                <dataScope>question_id</dataScope>
            </settings>
        </field>
        <field name="title" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">question</item>
                </item>
            </argument>
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Title</label>
                <dataScope>title</dataScope>
            </settings>
        </field>
        <field name="url_key" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">question</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">URL Key</label>
                <dataScope>url_key</dataScope>
            </settings>
        </field>
        <field name="status" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="options" xsi:type="object">Magendoo\Faq\Model\Source\Question\Status</item>
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">question</item>
                    <item name="default" xsi:type="string">pending</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Status</label>
                <dataScope>status</dataScope>
            </settings>
        </field>
        <field name="visibility" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="options" xsi:type="object">Magendoo\Faq\Model\Source\Question\Visibility</item>
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">question</item>
                    <item name="default" xsi:type="string">none</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Visibility</label>
                <dataScope>visibility</dataScope>
            </settings>
        </field>
        <field name="position" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">question</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Position</label>
                <dataScope>position</dataScope>
            </settings>
        </field>
        <field name="is_show_full_answer" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">question</item>
                    <item name="default" xsi:type="number">0</item>
                </item>
            </argument>
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Show Full Answer</label>
                <dataScope>is_show_full_answer</dataScope>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="number">0</map>
                            <map name="true" xsi:type="number">1</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>
        <field name="hide_direct_url" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">question</item>
                    <item name="default" xsi:type="number">0</item>
                </item>
            </argument>
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Hide Direct URL</label>
                <dataScope>hide_direct_url</dataScope>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="number">0</map>
                            <map name="true" xsi:type="number">1</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>
    </fieldset>
    <!-- Answer Fieldset -->
    <fieldset name="answer">
        <settings>
            <label translate="true">Answer</label>
            <collapsible>true</collapsible>
            <opened>true</opened>
        </settings>
        <field name="short_answer" formElement="textarea">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">question</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Short Answer</label>
                <dataScope>short_answer</dataScope>
            </settings>
        </field>
        <field name="full_answer" formElement="wysiwyg">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">question</item>
                    <item name="wysiwygConfigData" xsi:type="array">
                        <item name="is_pagebuilder_enabled" xsi:type="boolean">false</item>
                        <item name="toggle_button" xsi:type="boolean">true</item>
                        <item name="height" xsi:type="string">300px</item>
                        <item name="add_variables" xsi:type="boolean">false</item>
                        <item name="add_widgets" xsi:type="boolean">false</item>
                        <item name="add_images" xsi:type="boolean">true</item>
                        <item name="add_directives" xsi:type="boolean">true</item>
                    </item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Full Answer</label>
                <dataScope>full_answer</dataScope>
            </settings>
        </field>
    </fieldset>
    <!-- Customer Info Fieldset -->
    <fieldset name="customer_info">
        <settings>
            <label translate="true">Customer Information</label>
            <collapsible>true</collapsible>
            <opened>false</opened>
        </settings>
        <field name="sender_name" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">question</item>
                    <item name="disabled" xsi:type="boolean">true</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Sender Name</label>
                <dataScope>sender_name</dataScope>
            </settings>
        </field>
        <field name="sender_email" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">question</item>
                    <item name="disabled" xsi:type="boolean">true</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Sender Email</label>
                <dataScope>sender_email</dataScope>
            </settings>
        </field>
        <field name="customer_id" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">question</item>
                    <item name="disabled" xsi:type="boolean">true</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Customer ID</label>
                <dataScope>customer_id</dataScope>
            </settings>
        </field>
    </fieldset>
    <!-- Store Views Fieldset -->
    <fieldset name="store_views">
        <settings>
            <label translate="true">Store Views</label>
            <collapsible>true</collapsible>
            <opened>true</opened>
        </settings>
        <field name="store_ids" formElement="multiselect">
            <argument name="data" xsi:type="array">
                <item name="options" xsi:type="object">Magento\Store\Ui\Component\Listing\Column\Store\Options</item>
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">question</item>
                    <item name="default" xsi:type="array">
                        <item name="0" xsi:type="string">0</item>
                    </item>
                </item>
            </argument>
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <dataType>int</dataType>
                <label translate="true">Store Views</label>
                <dataScope>store_ids</dataScope>
            </settings>
        </field>
    </fieldset>
    <!-- Assign to FAQ Categories -->
    <fieldset name="faq_categories">
        <settings>
            <label translate="true">FAQ Categories</label>
            <collapsible>true</collapsible>
            <opened>true</opened>
        </settings>
        <field name="category_ids" formElement="multiselect">
            <argument name="data" xsi:type="array">
                <item name="options" xsi:type="object">Magendoo\Faq\Model\Source\CategoryOptions</item>
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">question</item>
                </item>
            </argument>
            <settings>
                <dataType>int</dataType>
                <label translate="true">Assign to FAQ Categories</label>
                <dataScope>category_ids</dataScope>
                <notice translate="true">Select one or more FAQ categories where this question should appear.</notice>
            </settings>
        </field>
    </fieldset>
    <!-- Assign to Products -->
    <fieldset name="products">
        <settings>
            <label translate="true">Related Products</label>
            <collapsible>true</collapsible>
            <opened>true</opened>
        </settings>
        <field name="product_ids" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">question</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Product IDs (comma-separated)</label>
                <dataScope>product_ids</dataScope>
                <notice translate="true">Enter one or more product entity IDs separated by commas. Example: 1,24,57. The question will appear on the "Product Questions" tab on each listed product's page.</notice>
            </settings>
        </field>
    </fieldset>
    <!-- SEO Fieldset -->
    <fieldset name="seo">
        <settings>
            <label translate="true">Search Engine Optimization</label>
            <collapsible>true</collapsible>
            <opened>false</opened>
        </settings>
        <field name="meta_title" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">question</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Meta Title</label>
                <dataScope>meta_title</dataScope>
            </settings>
        </field>
        <field name="meta_description" formElement="textarea">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">question</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Meta Description</label>
                <dataScope>meta_description</dataScope>
            </settings>
        </field>
        <field name="canonical_url" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">question</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Canonical URL</label>
                <dataScope>canonical_url</dataScope>
            </settings>
        </field>
        <field name="noindex" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">question</item>
                    <item name="default" xsi:type="number">0</item>
                </item>
            </argument>
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Noindex</label>
                <dataScope>noindex</dataScope>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="number">0</map>
                            <map name="true" xsi:type="number">1</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>
        <field name="nofollow" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">question</item>
                    <item name="default" xsi:type="number">0</item>
                </item>
            </argument>
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Nofollow</label>
                <dataScope>nofollow</dataScope>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="number">0</map>
                            <map name="true" xsi:type="number">1</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>
        <field name="exclude_sitemap" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">question</item>
                    <item name="default" xsi:type="number">0</item>
                </item>
            </argument>
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Exclude from Sitemap</label>
                <dataScope>exclude_sitemap</dataScope>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="number">0</map>
                            <map name="true" xsi:type="number">1</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>
    </fieldset>
</form>
