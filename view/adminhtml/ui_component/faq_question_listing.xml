<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">faq_question_listing.faq_question_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label translate="true">Add New Question</label>
            </button>
        </buttons>
        <spinner>faq_question_columns</spinner>
        <deps>
            <dep>faq_question_listing.faq_question_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="faq_question_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">question_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Magendoo_Faq::questions</aclResource>
        <dataProvider class="Magendoo\Faq\Ui\DataProvider\QuestionDataProvider" name="faq_question_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>question_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filterSearch name="keyword"/>
        <filters name="listing_filters"/>
        <massaction name="listing_massaction">
            <action name="delete">
                <settings>
                    <confirm>
                        <message translate="true">Are you sure you want to delete selected questions?</message>
                        <title translate="true">Delete Questions</title>
                    </confirm>
                    <url path="faq/question/massDelete"/>
                    <type>delete</type>
                    <label translate="true">Delete</label>
                </settings>
            </action>
            <action name="mark_answered">
                <argument name="data" xsi:type="array">
                    <item name="config" xsi:type="array">
                        <item name="type" xsi:type="string">mark_answered</item>
                        <item name="label" xsi:type="string" translate="true">Mark as Answered</item>
                        <item name="url" xsi:type="url" path="faq/question/massStatus">
                            <param name="status">answered</param>
                        </item>
                    </item>
                </argument>
            </action>
            <action name="mark_pending">
                <argument name="data" xsi:type="array">
                    <item name="config" xsi:type="array">
                        <item name="type" xsi:type="string">mark_pending</item>
                        <item name="label" xsi:type="string" translate="true">Mark as Pending</item>
                        <item name="url" xsi:type="url" path="faq/question/massStatus">
                            <param name="status">pending</param>
                        </item>
                    </item>
                </argument>
            </action>
            <action name="make_public">
                <argument name="data" xsi:type="array">
                    <item name="config" xsi:type="array">
                        <item name="type" xsi:type="string">make_public</item>
                        <item name="label" xsi:type="string" translate="true">Make Public</item>
                        <item name="url" xsi:type="url" path="faq/question/massVisibility">
                            <param name="visibility">public</param>
                        </item>
                    </item>
                </argument>
            </action>
            <action name="hide">
                <argument name="data" xsi:type="array">
                    <item name="config" xsi:type="array">
                        <item name="type" xsi:type="string">hide</item>
                        <item name="label" xsi:type="string" translate="true">Hide</item>
                        <item name="url" xsi:type="url" path="faq/question/massVisibility">
                            <param name="visibility">none</param>
                        </item>
                    </item>
                </argument>
            </action>
        </massaction>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="faq_question_columns">
        <selectionsColumn name="ids">
            <settings>
                <indexField>question_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="question_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>
        <column name="title">
            <settings>
                <filter>text</filter>
                <label translate="true">Title</label>
            </settings>
        </column>
        <column name="status" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="Magendoo\Faq\Model\Source\Question\Status"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Status</label>
            </settings>
        </column>
        <column name="visibility" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="Magendoo\Faq\Model\Source\Question\Visibility"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Visibility</label>
            </settings>
        </column>
        <column name="position">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Position</label>
            </settings>
        </column>
        <column name="sender_name">
            <settings>
                <filter>text</filter>
                <label translate="true">Sender Name</label>
            </settings>
        </column>
        <column name="sender_email">
            <settings>
                <filter>text</filter>
                <label translate="true">Sender Email</label>
            </settings>
        </column>
        <column name="view_count">
            <settings>
                <filter>textRange</filter>
                <label translate="true">View Count</label>
            </settings>
        </column>
        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Created</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="Magendoo\Faq\Ui\Component\Listing\Column\QuestionActions">
            <settings>
                <indexField>question_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
