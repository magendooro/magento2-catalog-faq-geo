<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="content">
            <block class="Magendoo\Faq\Block\Faq\Question\View" name="faq.question.view" template="Magendoo_Faq::question/view.phtml">
                <block class="Magendoo\Faq\Block\Faq\Question\Rating" name="faq.question.rating" as="rating"/>
                <block class="Magendoo\Faq\Block\Faq\Question\SocialShare" name="faq.question.social" as="social" template="Magendoo_Faq::question/social-share.phtml"/>
            </block>
        </referenceContainer>
        <referenceContainer name="head.additional">
            <block class="Magendoo\Faq\Block\Faq\StructuredData" name="faq.structured.data" template="Magendoo_Faq::structured-data.phtml" ifconfig="magendoo_faq/seo/structured_data_enabled"/>
        </referenceContainer>
    </body>
</page>
