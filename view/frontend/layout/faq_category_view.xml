<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="content">
            <block class="Magendoo\Faq\Block\Faq\Category\View" name="faq.category.view" template="Magendoo_Faq::category/view.phtml"/>
        </referenceContainer>
        <referenceContainer name="head.additional">
            <block class="Magendoo\Faq\Block\Faq\StructuredData"
                   name="faq.category.structured.data"
                   template="Magendoo_Faq::structured-data.phtml"
                   ifconfig="magendoo_faq/seo/structured_data_enabled"/>
        </referenceContainer>
    </body>
</page>
