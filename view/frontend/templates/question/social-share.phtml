/** @var \Magendoo\Faq\Block\Faq\Question\SocialShare $block */
?>
<?php if ($block->isEnabled() && $block->getQuestion()): ?>
<div class="faq-social-share">
    <span class="share-label"><?= $block->escapeHtml(__('Share:')) ?></span>
    <?php foreach ($block->getNetworks() as $network): ?>
        <?php $shareUrl = $block->getShareUrl($network); ?>
        <?php if ($shareUrl === ''): ?>
            <?php continue; ?>
        <?php endif; ?>
        <a href="<?= $block->escapeUrl($shareUrl) ?>"
           target="_blank" rel="noopener noreferrer nofollow"
           class="faq-share faq-share--<?= $block->escapeHtmlAttr($network) ?>"
           title="<?= $block->escapeHtmlAttr(__('Share on %1', ucfirst($network))) ?>">
            <?= $block->escapeHtml(ucfirst($network)) ?>
        </a>
    <?php endforeach; ?>
</div>
<?php endif; ?>
