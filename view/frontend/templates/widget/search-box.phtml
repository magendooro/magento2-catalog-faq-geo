/** @var \Magendoo\Faq\Block\Widget\SearchBox $block */
?>
<div class="faq-widget faq-widget-search">
    <?php if ($block->getBlockTitle()): ?>
    <h3 class="faq-widget-title"><?= $block->escapeHtml($block->getBlockTitle()) ?></h3>
    <?php endif; ?>
    <form action="<?= $block->escapeUrl($block->getSearchUrl()) ?>" method="get" class="faq-search-form">
        <div class="field search">
            <input type="text" name="q" class="input-text"
                   placeholder="<?= $block->escapeHtmlAttr($block->getPlaceholder()) ?>"
                   autocomplete="off"/>
            <button type="submit" class="action search">
                <span><?= $block->escapeHtml(__('Search')) ?></span>
            </button>
        </div>
    </form>
</div>
